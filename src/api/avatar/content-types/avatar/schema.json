{
  "kind": "collectionType",
  "collectionName": "avatars",
  "info": {
    "singularName": "avatar",
    "pluralName": "avatars",
    "displayName": "Avatar"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "owner": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "platform": {
      "type": "enumeration",
      "enum": [
        "Android",
        "PC"
      ],
