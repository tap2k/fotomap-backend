{
  "kind": "collectionType",
  "collectionName": "channels",
  "info": {
    "singularName": "channel",
    "pluralName": "channels",
    "displayName": "Channel",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uniqueID": {
      "type": "uid",
      "required": true
    },
    "name": {
      "type": "string"
    },
    "public": {
      "type": "boolean",
      "default": true,
      "required": false
    },
    "owner": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "lat": {
      "type": "float"
    },
    "long": {
      "type": "float"
    },
    "zoom": {
      "type": "float"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::channel.channel",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::channel.channel",
      "mappedBy": "parent"
    },
    "editors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "tileset": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tileset.tileset"
    },
    "picture": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "allowsubmissions": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "richtext"
    },
    "interval": {
      "type": "integer"
    },
    "overlays": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::overlay.overlay",
      "mappedBy": "channel"
    },
    "assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::asset.asset",
      "mappedBy": "channel"
    },
    "contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content.content",
      "mappedBy": "channel"
    },
    "markercolor": {
      "type": "enumeration",
      "enum": [
        "none",
        "black",
        "blue",
        "gold",
        "green",
        "grey",
        "orange",
        "red",
        "violet",
        "yellow"
      ]
    },
    "order": {
      "type": "integer"
    },
    "markericon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag",
      "mappedBy": "channel"
    },
    "audiofile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "audios"
      ]
    },
    "showtitle": {
      "type": "boolean",
      "default": true
    },
    "email": {
      "type": "email"
    },
    "location": {
      "type": "string"
    }
  }
}
