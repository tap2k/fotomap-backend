{
  "kind": "collectionType",
  "collectionName": "channels",
  "info": {
    "singularName": "channel",
    "pluralName": "channels",
    "displayName": "Channel",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uniqueID": {
      "type": "uid",
      "required": true
    },
    "name": {
      "type": "string"
    },
    "public": {
      "type": "boolean",
      "default": true,
      "required": false
    },
    "owner": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "lat": {
      "type": "float"
    },
    "long": {
      "type": "float"
    },
    "zoom": {
      "type": "float"
    },
    "parent": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::channel.channel"
    },
    "editors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "tileset": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tileset.tileset"
    },
    "picture": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "allowsubmissions": {
      "type": "boolean"
    },
    "description": {
      "type": "richtext"
    },
    "interval": {
      "type": "integer"
    },
    "overlay": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::overlay.overlay",
      "inversedBy": "channel"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag",
      "mappedBy": "channel"
    }
  }
}
