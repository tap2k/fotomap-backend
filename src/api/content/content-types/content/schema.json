{
  "kind": "collectionType",
  "collectionName": "contents",
  "info": {
    "singularName": "content",
    "pluralName": "contents",
    "displayName": "Content",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "channel": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::channel.channel",
      "inversedBy": "contents"
    },
    "order": {
      "type": "integer"
    },
    "mediafile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "ext_url": {
      "type": "text"
    },
    "is360": {
      "type": "boolean",
      "default": false,
      "required": false
    },
    "mapping": {
      "type": "enumeration",
      "enum": [
        "normal",
        "equirect180",
        "equirect360",
        "cubemap",
        "eac",
        "unknown"
      ],
      "default": "unknown"
    },
    "packing": {
      "type": "enumeration",
      "enum": [
        "none",
        "topbottom",
        "leftright",
        "twotextures",
        "eac3d",
        "eac",
        "custom",
        "unknown"
      ],
      "default": "unknown"
    },
    "lat": {
      "type": "float"
    },
    "long": {
      "type": "float"
    },
    "markercolor": {
      "type": "enumeration",
      "enum": [
        "none",
        "black",
        "blue",
        "gold",
        "green",
        "grey",
        "orange",
        "red",
        "violet",
        "yellow"
      ],
      "default": "none"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "contents"
    },
    "textalignment": {
      "type": "enumeration",
      "enum": [
        "top",
        "center",
        "bottom"
      ],
      "default": "top"
    },
    "audiofile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "audios"
      ]
    },
    "email": {
      "type": "email"
    },
    "name": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "start_time": {
      "type": "float"
    },
    "duration": {
      "type": "float"
    }
  }
}
