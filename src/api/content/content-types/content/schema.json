{
  "kind": "collectionType",
  "collectionName": "contents",
  "info": {
    "singularName": "content",
    "pluralName": "contents",
    "displayName": "Content",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "channel": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::channel.channel"
    },
    "order": {
      "type": "integer"
    },
    "mediafile": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "ext_url": {
      "type": "string"
    },
    "is360": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "mapping": {
      "type": "enumeration",
      "enum": [
        "normal",
        "equirect180",
        "equirect360",
        "cubemap",
        "unknown"
      ],
      "default": "unknown"
    },
    "packing": {
      "type": "enumeration",
      "enum": [
        "topbottom",
        "leftright",
        "custom",
        "unknown"
      ],
      "default": "unknown"
    }
  }
}
